def create_hybrid(base_path):
    # This function blends the "bad" patterns
    hybrids = [
        f"..%252f..;/{base_path}",     # Double Encoding + Semicolon
        f"..%u2215..%252f{base_path}",  # Unicode + Double Encoding
        f"/%2e%2e%2f..;/{base_path}",   # Hex Dot + Semicolon
    ]
    return random.choice(hybrids)

