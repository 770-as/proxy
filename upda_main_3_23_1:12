# --- AI CORE: TRAINING ---
def train_agent(data_list):
    df = pd.DataFrame(data_list)
   
    # 1. Fit the TF-IDF (The Senses)
    payload_vectors = tfidf.fit_transform(df['payload'].fillna(''))
    feature_names = tfidf.get_feature_names_out().tolist()
    all_feature_names = feature_names + ["WAF_CODE", "LOG_LATENCY"]
   
    # 2. Prepare Features
    waf_scores = df['waf_reaction_code'].astype(float).values.reshape(-1, 1)
    latencies = np.log1p(df['latency_ms'].astype(float)).values.reshape(-1, 1)
    X = np.hstack((payload_vectors.toarray(), waf_scores, latencies))
   
    # 3. PROXIMITY SCORING (The "Heat Map")
    y = []
    for _, row in df.iterrows():
        score = 0.0
        # If it's a 200 or 500, it's a massive win
        if row['status_code'] in [200, 500]:
            score = 1.0
        # If the WAF code is one that usually precedes a bypass
        elif str(row['waf_reaction_code']) in ['341', '344']:
            score = 0.8
        # If the server took a long time to answer (Potential "Hanging" WAF)
        elif row['latency_ms'] > 2000:
            score = 0.4
        
        y.append(1 if score > 0.3 else 0) # We still use 1/0 for the model, but we 'promote' interesting failures to 1
        # If we have NO successes in our data, add a 'Ghost' success to prevent the crash
        if sum(y) == 0:
            y[0] = 1 # Force the first item to be a 'Success' so the model has 2 columns
    # ... (Rest of the training) ...
    # 4. Train the Random Forest (The Brain)
    clf = RandomForestClassifier(n_estimators=100)
    clf.fit(X, y)
   
# Create directory if it doesn't exist
    path = f"models/{context_name}/"
    if not os.path.exists(path): os.makedirs(path)
    
    # SAVE WITH CONTEXT NAME
    joblib.dump(clf, f"{path}model.pkl")
    joblib.dump(tfidf, f"{path}tfidf.pkl")
    
    with open(f"{path}history.json", 'w') as f:
        json.dump(data_list, f)
        
    print(f"[*] Brain updated for context: {context_name}")
    # 5. Output reasoning to the terminal
    importances = clf.feature_importances_
    indices = np.argsort(importances)[::-1]
   
    print("\n" + "="*50)
    print("      [MODEL SAVED & ANALYZED]      ")
    print("="*50)
    for i in range(min(5, len(all_feature_names))):
        print(f"Top Feature {i+1}: {all_feature_names[indices[i]]}")
    print("="*50 + "\n")
   
    return clf
