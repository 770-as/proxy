@app.route('/train', methods=['POST'])
def train():
    try:
        data = request.get_json()
        
        # If data is a list (Bulk Training), loop through it
        if isinstance(data, list):
            for entry in data:
                process_entry(entry)
            return jsonify({"status": "success", "message": f"Processed {len(data)} items"}), 200
        
        # If data is a single dictionary
        else:
            process_entry(data)
            return jsonify({"status": "success", "message": "Training data received"}), 200

    except Exception as e:
        return jsonify({"status": "error", "message": str(e)}), 500

def process_entry(entry):
    url = entry.get('url')
    label = entry.get('label')
    print(f"--- TRAINING RECEIVED ---")
    print(f"URL: {url} | LABEL: {label}")

